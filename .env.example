# -----------------------------------------------
# .env.example — SAFE TO COMMIT
# Copy this file to .env and fill in real values.
# DO NOT put real credentials in this file.
# -----------------------------------------------

# PostgreSQL connection string
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL="postgresql://postgres:your_password_here@localhost:5432/capstone"

# JWT Secret Key — used to sign and verify auth tokens
# Generate a strong random key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here

# MongoDB URI — for Big Data trends endpoint
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=big-data

# SMTP Configuration
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password_here
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_FROM_EMAIL=your_email@gmail.com
# SMTP_USE_TLS=true

